# Atlas dev environment configuration template.
# Copy to .env and fill in the secrets that aren't already in 1Password.

# Neo4j (matches docker-compose.yml)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=atlasdev

# Anthropic — Atlas's primary LLM provider
# Resolved from 1Password Developer vault at session start
ANTHROPIC_API_KEY=

# Optional fallback LLM for cheaper bulk operations
OPENAI_API_KEY=

# Atlas data directory (state, ledger, caches)
ATLAS_DATA_DIR=~/.atlas

# Daily LLM ingestion budget cap (USD)
ATLAS_DAILY_LLM_BUDGET_USD=5.00

# Atlas namespace — use "Atlas" for the public dev workspace,
# "AtlasSP" for Rich's private SP instance
ATLAS_PROJECT_NAMESPACE=Atlas

# Logging
ATLAS_LOG_LEVEL=INFO
